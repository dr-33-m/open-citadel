{
  "expo": {
    "name": "Open Citadel",
    "slug": "open-citadel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-dark.png",
    "scheme": "opencitadel",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": {
        "light": "./assets/icons/ios-light.png",
        "dark": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.dr33m.opencitadel",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/oc-adaptive-icon.png",
        "backgroundColor": "#131313"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.dr33m.opencitadel",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/ios-dark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/icons/splash-icon-light.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#131313",
            "image": "./assets/icons/oc-splash-icon-dark.png"
          }
        }
      ],
      "expo-sqlite",
      "expo-document-picker",
      "expo-file-system",
      "./plugins/withCoreDesugaring",
      "./plugins/withCleartextTraffic",
      [
        "./plugins/withGradleVersion",
        "8.13"
      ],
      "./plugins/withAbiFilters",
      "./plugins/withReadiumPodfile",
      "@dr33m/react-native-litert-lm",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "minSdkVersion": 26,
            "enableCoreLibraryDesugaring": true
          },
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-sharing",
      "./plugins/withBackgroundAudio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5cb454f2-63c2-4422-85c4-61cf5b57a0c5"
      }
    }
  }
}
